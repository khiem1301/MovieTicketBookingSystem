# =============================================================================
# ÉPCINE — email.properties (GỬI MAIL XÁC THỰC ĐĂNG KÝ — FR-01)
# =============================================================================
#
# Hướng dẫn đầy đủ từng bước: README.md → mục "3. Cấu hình Email SMTP"
#
# BƯỚC 1 — Tạo file trên máy bạn bằng CMD hoặc PowerShell (chạy tại thư mục gốc project):
#   copy src\main\resources\email.properties.example src\main\resources\email.properties
#
# BƯỚC 2 — Copy phần SMTP nhóm (8 dòng dưới) — GIỮ NGUYÊN 8 dòng không cần sửa
# BƯỚC 3 — Sửa DUY NHẤT app.base.url theo URL Tomcat trên máy bạn
#
# =============================================================================

mail.smtp.host=smtp.gmail.com
mail.smtp.port=587
mail.smtp.auth=true
mail.smtp.starttls.enable=true
mail.smtp.username=epcine88@gmail.com
mail.smtp.password=<app-password-16-ky-tu>
mail.from=epcine88@gmail.com
mail.from.name=ÉPCINE
app.base.url=http://localhost:<PORT>/<CONTEXT_PATH>
