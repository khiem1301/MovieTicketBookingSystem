# =============================================================================
# ÉPCINE — google.properties (ĐĂNG NHẬP BẰNG GOOGLE — OAuth 2.0)
# =============================================================================
#
# Hướng dẫn đầy đủ từng bước: README.md → mục "4. Cấu hình Google OAuth"
#
# BƯỚC 1 — Tạo file trên máy bạn bằng CMD hoặc PowerShell (chạy tại thư mục gốc project):
#   copy src\main\resources\google.properties.example src\main\resources\google.properties
#
# BƯỚC 2 — Điền Client ID + Secret (lấy từ admin nhóm qua Zalo/Discord — KHÔNG ghi secret thật lên Git)
# BƯỚC 3 — Sửa google.redirect.uri = app.base.url + /auth/google/callback
#           Gửi URL callback cho admin (Gia Long) để thêm trên Google Console nếu chưa có
#
# =============================================================================

google.client.id=<google-client-id>.apps.googleusercontent.com
google.client.secret=<google-client-secret>
google.redirect.uri=http://localhost:<PORT>/<CONTEXT_PATH>/auth/google/callback
